# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://libraiq:secret@db:5432/libraiq"
POSTGRES_USER="libraiq"
POSTGRES_PASSWORD="secret"
POSTGRES_DB="libraiq"

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── NextAuth ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-32-byte-hex-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── ML Microservice ─────────────────────────────────────────────────────
ML_SERVICE_URL="http://ml:8000"
ML_SERVICE_SECRET="change-this-ml-secret"

# ─── Email ────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="LibraIQ <noreply@example.com>"

# ─── Cron ─────────────────────────────────────────────────────────────────
CRON_SECRET="change-this-cron-secret"
